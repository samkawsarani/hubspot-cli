{
  "name": "@samkawsarani/hubspot-cli",
  "version": "1.1.0",
  "description": "HubSpot CRM API integration — search and read operations with CLI",
  "license": "MIT",
  "homepage": "https://github.com/samkawsarani/hubspot-cli#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/samkawsarani/hubspot-cli.git"
  },
  "bugs": {
    "url": "https://github.com/samkawsarani/hubspot-cli/issues"
  },
  "type": "module",
  "main": "./dist/lib/index.js",
  "types": "./dist/lib/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/lib/index.d.ts",
      "import": "./dist/lib/index.js",
      "default": "./dist/lib/index.js"
    }
  },
  "engines": {
    "node": ">=18"
  },
  "bin": {
    "hubspot": "./dist/hubspot.js"
  },
  "scripts": {
    "build": "bash scripts/build.sh",
    "test": "bun test",
    "prepublishOnly": "bun run build"
  },
  "files": [
    "dist/",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "dependencies": {
    "commander": "^12",
    "dotenv": "^16"
  },
  "devDependencies": {
    "@types/node": "^22",
    "typescript": "^5"
  }
}
